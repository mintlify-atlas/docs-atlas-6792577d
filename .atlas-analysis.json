{
  "projectType": "frontend",
  "projectName": "Network Analysis",
  "projectDescription": "Interactive client-side web application for visualizing and analyzing network relationships from Excel data with Sankey diagrams, force-directed graphs, ego networks, and geographic maps.",
  "theme": "palm",
  "primaryColor": "#fcc72c",
  "lightColor": "#f5d8d5",
  "darkColor": "#1c3c44",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "Visualizations",
            "pages": [
              "visualizations/sankey",
